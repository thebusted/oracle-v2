# Oracle v2 Environment Variables
# Copy to .env and fill in values

# Server
PORT=47778
ORACLE_SESSION_SECRET=           # Random string for session signing (auto-generated if empty)
CORS_ORIGIN=                     # Allowed CORS origin for production (e.g., https://yourdomain.com)

# Database
ORACLE_DATA_DIR=                 # Path to Oracle data directory (default: ~/.oracle)

# Vector Store (choose one)
CHROMA_URL=http://localhost:8000
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embeddings
OPENAI_API_KEY=                  # For OpenAI embeddings
OLLAMA_BASE_URL=http://localhost:11434  # For local Ollama embeddings

# Cloudflare (optional)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
ORACLE_EMBEDDING_MODEL=

# Forum (optional)
ORACLE_FORUM_REPO=               # GitHub repo for forum sync (e.g., owner/repo)

# Source mappings (optional JSON)
ORACLE_SOURCE_MAPPINGS=          # e.g., {"key":"github.com/owner/repo"}
